{
	"name": "n8n-nodes-loops",
	"version": "0.1.2",
	"description": "n8n community node for Loops (loops.so) — manage contacts, send events, and transactional emails",
	"keywords": [
		"n8n-community-node-package",
		"loops",
		"email",
		"marketing",
		"transactional"
	],
	"license": "MIT",
	"homepage": "https://github.com/fredfrom/n8n-nodes-loops",
	"author": {
		"name": "Friedemann Frommelt",
		"email": "friedemannfrommelt1996@gmail.com"

	},
	"repository": {
		"type": "git",
		"url": "https://github.com/fredfrom/n8n-nodes-loops.git"
	},
	"main": "dist/index.js",
	"files": [
		"dist"
	],
	"scripts": {
		"build": "n8n-node build",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release",
		"prepublishOnly": "npm run build && npm run lint",
		"test": "jest"
	},
	"jest": {
		"preset": "ts-jest",
		"testEnvironment": "node",
		"roots": ["<rootDir>/test"],
		"testMatch": ["**/*.test.ts"]
	},
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"credentials": [
			"dist/credentials/LoopsApi.credentials.js",
			"dist/credentials/LoopsWebhookApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/Loops/Loops.node.js",
			"dist/nodes/Loops/LoopsTrigger.node.js"
		]
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	},
	"devDependencies": {
		"@n8n/node-cli": "*",
		"@types/jest": "^29.5.14",
		"eslint": "^9.0.0",
		"jest": "^29.7.0",
		"prettier": "^3.0.0",
		"release-it": "*",
		"ts-jest": "^29.4.6",
		"typescript": "^5.0.0"
	}
}
